<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="750.0" prefWidth="950.0" style="-fx-background-color: #faf4ed;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.group1.myvitals.controller.PersonDetailsPageController">
    
    <stylesheets>
        <URL value="@chartStyle.css" />
    </stylesheets>

    <children>
        <VBox spacing="25.0" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="30.0" AnchorPane.rightAnchor="30.0" AnchorPane.topAnchor="15.0">
            <children>
                
                <AnchorPane>
                    <children>
                        <Label text="Personal Details" textFill="#575279" AnchorPane.leftAnchor="0.0" AnchorPane.topAnchor="0.0">
                     <font>
                        <Font name="Aptos Display Bold" size="48.0" />
                     </font></Label>
                        
                        <Button fx:id="PersonalDetailsMainEditSaveButton" onAction="#mainEditSaveButtonPressed" prefHeight="35.0" prefWidth="130.0" styleClass="button-primary" stylesheets="@../css/chartStyle.css" text="Edit Profile" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="5.0" />
                    </children>
                </AnchorPane>

                <VBox spacing="20.0">
                    <children>
                        
                        <HBox spacing="40.0">
                            <children>
                                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label style="-fx-font-family: 'Aptos Mono'; -fx-font-weight: bold; -fx-text-fill: #575279; -fx-font-size: 16;" text="First Name:" />
                                        <TextField fx:id="PersonalDetailsFirstNameTextBox" editable="false" prefHeight="35.0" stylesheets="@../css/chartStyle.css" />
                                    </children>
                                </VBox>
                                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label style="-fx-font-family: 'Aptos Mono'; -fx-font-weight: bold; -fx-text-fill: #575279; -fx-font-size: 16;" text="Last Name:" />
                                        <TextField fx:id="PersonalDetailsLastNameTextBox" editable="false" prefHeight="35.0" stylesheets="@../css/chartStyle.css" />
                                    </children>
                                </VBox>
                            </children>
                        </HBox>

                        <HBox spacing="40.0">
                            <children>
                                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label style="-fx-font-family: 'Aptos Mono'; -fx-font-weight: bold; -fx-text-fill: #575279; -fx-font-size: 16;" text="NHI:" />
                                        <TextField fx:id="PersonalDetailsNHITextBox" editable="false" prefHeight="35.0" stylesheets="@../css/chartStyle.css" />
                                    </children>
                                </VBox>
                                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label style="-fx-font-family: 'Aptos Mono'; -fx-font-weight: bold; -fx-text-fill: #575279; -fx-font-size: 16;" text="Gender:" />
                                        <TextField fx:id="PersonalDetailsGenderTextBox" editable="false" prefHeight="35.0" stylesheets="@../css/chartStyle.css" />
                                    </children>
                                </VBox>
                            </children>
                        </HBox>

                        <HBox spacing="40.0">
                            <children>
                                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label style="-fx-font-family: 'Aptos Mono'; -fx-font-weight: bold; -fx-text-fill: #575279; -fx-font-size: 16;" text="Date of Birth:" />
                                        <TextField fx:id="PersonalDetailsDOBTextBox" editable="false" prefHeight="35.0" stylesheets="@../css/chartStyle.css" />
                                    </children>
                                </VBox>
                                <VBox prefWidth="120.0" spacing="5.0">
                                    <children>
                                        <Label style="-fx-font-family: 'Aptos Mono'; -fx-font-weight: bold; -fx-text-fill: #575279; -fx-font-size: 16;" text="Age:" />
                                        <TextField fx:id="PersonalDetailsAgeTextBox" editable="false" prefHeight="35.0" stylesheets="@../css/chartStyle.css" />
                                    </children>
                                </VBox>
                                <VBox spacing="5.0" stylesheets="@../css/chartStyle.css" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label style="-fx-font-family: 'Aptos Mono'; -fx-font-weight: bold; -fx-text-fill: #575279; -fx-font-size: 16;" text="Height:" />
                                        <TextField fx:id="PersonalDetailsHeightTextBox" editable="false" prefHeight="35.0" />
                                    </children>
                                </VBox>
                            </children>
                        </HBox>
                    </children>
                </VBox>

                <HBox spacing="40.0" VBox.vgrow="ALWAYS">
                    <children>
                        
                        <VBox spacing="10.0" HBox.hgrow="ALWAYS">
                            <children>
                                <Label style="-fx-font-family: 'Aptos Mono'; -fx-font-weight: bold; -fx-text-fill: #575279; -fx-font-size: 16px;" text="Medications:" />
                                <TableView fx:id="PersonalDetailsMedicationsTable" stylesheets="@../css/chartStyle.css" VBox.vgrow="ALWAYS">
                                  <columns>
                                    <TableColumn fx:id="medNameColumn" prefWidth="200.0" text="Name" />
                                    <TableColumn fx:id="medDosageColumn" prefWidth="200.0" text="Dosage" />
                                  </columns>
                                   <columnResizePolicy>
                                      <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                   </columnResizePolicy>
                                </TableView>
                                <HBox spacing="15.0">
                                    <children>
                                        <Button fx:id="PersonalDetailsAddMedicationButton" disable="true" prefHeight="30.0" prefWidth="100.0" styleClass="button-secondary" stylesheets="@../css/chartStyle.css" text="Add" />
                                        <Button fx:id="PersonalDetailsEditMedicationButton" disable="true" prefHeight="30.0" prefWidth="100.0" styleClass="button-secondary" stylesheets="@../css/chartStyle.css" text="Edit" />
                                        <Button fx:id="PersonalDetailsRemoveMedicationButton" disable="true" prefHeight="30.0" prefWidth="100.0" styleClass="button-secondary" stylesheets="@../css/chartStyle.css" text="Remove" />
                                    </children>
                                </HBox>
                            </children>
                        </VBox>

                        <VBox spacing="10.0" HBox.hgrow="ALWAYS">
                            <children>
                                <Label style="-fx-font-family: 'Aptos Mono'; -fx-font-weight: bold; -fx-text-fill: #575279; -fx-font-size: 16px;" text="Allergies:" />
                                <TableView fx:id="PersonalDetailsAllergiesTable" stylesheets="@../css/chartStyle.css" VBox.vgrow="ALWAYS">
                                  <columns>
                                    <TableColumn fx:id="allergyNameColumn" prefWidth="400.0" text="Name" />
                                  </columns>
                                   <columnResizePolicy>
                                      <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                   </columnResizePolicy>
                                </TableView>
                                <HBox spacing="15.0">
                                    <children>
                                        <Button fx:id="PersonalDetailsAddAllergyButton" disable="true" prefHeight="30.0" prefWidth="100.0" styleClass="button-secondary" stylesheets="@../css/chartStyle.css" text="Add" />
                                        <Button fx:id="PersonalDetailsRemoveAllergyButton" disable="true" prefHeight="30.0" prefWidth="100.0" styleClass="button-secondary" stylesheets="@../css/chartStyle.css" text="Remove" />
                                    </children>
                                </HBox>
                            </children>
                        </VBox>
                        
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</AnchorPane>
